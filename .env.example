# Eral environment variables
# Secrets should be set via: wrangler secret put <NAME>
# Never commit real values to source control.

# ── Required ─────────────────────────────────────────────────────────────────
# Shared with WokAPI — must match exactly
JWT_SECRET=<openssl rand -hex 32>

# ── AI Providers ─────────────────────────────────────────────────────────────
# Primary: OpenAI GPT-4o — set this for best quality responses
OPENAI_API_KEY=sk-...

# ── Optional ─────────────────────────────────────────────────────────────────
# Error tracking
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Deployment environment (set in wrangler.toml [vars])
ENVIRONMENT=development
